# Copy this file to .env and fill in your values
# cp .env.example .env

# Database
DB_NAME=cost_optimizer
DB_USER=admin
DB_PASSWORD=changeme

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=<your-access-key>
AWS_SECRET_ACCESS_KEY=<your-secret-key>

# API Auth
JWT_SECRET_KEY=<generate-with: openssl rand -hex 32>
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# Notifications (leave blank to disable)
# Slack: create an Incoming Webhook at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=
# Teams: create an Incoming Webhook connector in your Teams channel
TEAMS_WEBHOOK_URL=

# Recommendation Engine
CPU_THRESHOLD=20.0
SAVINGS_PER_DOWNSIZE=45.00
